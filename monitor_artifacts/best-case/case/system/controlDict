        patch           outlet2;
        operation       sum;
        fields          (phi);
    }

    outlet3P
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        writeFields     false;
        patch           outlet3;
        operation       areaAverage;
        fields          (p);
    }

    outlet3Flow
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        writeFields     false;
        patch           outlet3;
        operation       sum;
        fields          (phi);
    }

    outlet4P
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        writeFields     false;
        patch           outlet4;
        operation       areaAverage;
        fields          (p);
    }

    outlet4Flow
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        writeFields     false;
        patch           outlet4;
        operation       sum;
