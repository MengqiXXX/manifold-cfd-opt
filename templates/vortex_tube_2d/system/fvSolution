FoamFile { format ascii; class dictionary; object fvSolution; }

solvers
{
    p
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-7;
        relTol          0.01;
    }
    "(U|h|e|k|omega)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.01;
    }
    rho { solver diagonal; }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;
    transonic               no;
    consistent              yes;
    residualControl
    {
        p       1e-4;
        U       1e-4;
        "(h|e)" 1e-4;
        k       1e-4;
        omega   1e-4;
    }
}

relaxationFactors
{
    fields  { p 0.5; rho 0.5; }
    equations
    {
        U       0.7;
        h       0.5;
        e       0.5;
        k       0.5;
        omega   0.5;
    }
}
