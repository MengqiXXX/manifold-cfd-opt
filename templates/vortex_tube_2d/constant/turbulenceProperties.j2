/*--------------------------------*- C++ -*----------------------------------*\
  OpenFOAM turbulenceProperties — k-omega SST
\*---------------------------------------------------------------------------*/
FoamFile
{
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}

simulationType  RAS;

RAS
{
    RASModel        kOmegaSST;
    turbulence      on;
    printCoeffs     on;
}
